# Backend API configuration example
# Copy to the server and fill in real values
# Reference via API_ENV_FILE in .env

# --- PostgreSQL ---
POSTGRES_USER=fitness
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_HOST=CHANGE_ME
POSTGRES_PORT=5432
POSTGRES_DB=fitness
POSTGRES_SSL_MODE=require

# --- Telegram ---
TELEGRAM_BOT_TOKEN=CHANGE_ME
TELEGRAM_TOKEN_EXPIRE_IN=24h

# --- LLM (OpenRouter) ---
OPENAI_API_KEY=CHANGE_ME

# --- AWS S3 ---
AWS_ENDPOINT=https://s3.example.com
AWS_ACCESS_KEY_ID=CHANGE_ME
AWS_SECRET_ACCESS_KEY=CHANGE_ME
AWS_S3_BUCKET=fitness-attachments
AWS_REGION=us-east-1

# --- Tracing ---
JAEGER_COLLECTOR_ENDPOINT=http://jaeger:14268/api/traces

# --- Proxy (optional) ---
PROXY_URL=
PROXY_USER=
PROXY_PASSWORD=

# --- Config path ---
CONFIG_PATH=/app/config.yaml
