COMPOSE_PROJECT_NAME=fitnesstrainer

# --- Registry ---
REGISTRY=6d631136-intelligent-corvus.registry.twcstorage.ru
IMAGE_TAG=latest

API_IMAGE=${REGISTRY}/fitnesstrainer-api:${IMAGE_TAG}
MIGRATE_IMAGE=${REGISTRY}/fitnesstrainer-migrate:${IMAGE_TAG}
FRONTEND_IMAGE=${REGISTRY}/fitnesstrainer-frontend:${IMAGE_TAG}
BOT_IMAGE=${REGISTRY}/fitnesstrainer-bot:${IMAGE_TAG}

# --- Domains ---
API_DOMAIN=api.fitness.yotechnologies.ru
FRONTEND_DOMAIN=fitness.yotechnologies.ru

# --- Config paths on the server ---
BACKEND_CONFIG=/root/fitnesstrainer/config.yaml
API_ENV_FILE=/root/fitnesstrainer/api.env
BOT_ENV_FILE=/root/fitnesstrainer/bot.env

# --- Traefik ---
TRAEFIK_ACME_EMAIL=admin@yotechnologies.ru
